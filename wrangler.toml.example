name = "r2-registry"

# Custom Cloudflare domain for worker: 
# routes = [
#  { pattern = "your.custom.domain", custom_domain = true } 
# ]

workers_dev = true #set to false to disable the default Worker domain (applicable only if custom domain is used instead)
main = "./index.ts"
compatibility_date = "2024-09-09"
compatibility_flags = ["nodejs_compat"]

## Production
[env.production]
r2_buckets = [
  { binding = "REGISTRY", bucket_name = "" }
]

# Weekly retention sweep: prunes excess semver tags then runs untagged GC per repo.
# Sunday 16:00 UTC (~05:00 Mon NZST) is a low-traffic window.
[env.production.triggers]
crons = ["0 16 * * SUN"]

# Allow the cron handler up to 5 minutes of CPU per invocation; the registry
# walks every repo serially and may issue many R2 deletes.
[env.production.limits]
cpu_ms = 300000

[env.production.vars]
# Optional full-match JavaScript regular expression for tags that must never be
# moved or deleted. This example protects strict vX.Y.Z releases while leaving
# operational tags such as `latest` mutable.
IMMUTABLE_TAG_PATTERN = 'v(?:0|[1-9]\d*)\.(?:0|[1-9]\d*)\.(?:0|[1-9]\d*)'
# Number of highest-precedence unprotected semver tags to keep per repo;
# protected and non-semver tags (e.g. `latest`, branch names) are preserved.
RETENTION_COUNT = "3"
# Set to "true" to log the deletion plan without touching anything. Flip to
# "false" once you've verified the plan in the logs.
RETENTION_DRY_RUN = "true"

# Secrets:
# USERNAME/PASSWORD/READONLY_USERNAME/READONLY_PASSWORD if you want username/password based auth


## Dev - For local dev using `npx wrangler dev`
[env.dev]
r2_buckets = [{ binding = "REGISTRY", bucket_name = "r2-image-registry-dev" }]

# Put local authentication values in .dev.vars, never in this file.
